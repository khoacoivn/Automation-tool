code repo mình để ở gitlab thì có thể dùng luôn gitlabci
sample:

variables:
  REGISTRY: "registry.homecredit.vn"
  IMAGE_PATH: "service_desk/sd-automation-hub"
  http_proxy: "http://proxy-server.homecredit.vn:8080"
  https_proxy: "http://proxy-server.homecredit.vn:8080"
  no_proxy: "localhost,127.0.0.1,.homecredit.vn,.homecredit.net,.eit.zone"

stages:
  - build
  - deploy

# ── Release (on git tag) ────────────────────────────────────────────────────────
build-app:
  stage: build
  only:
    - tags
  tags:
    - vn-small
  image: registry.vn.eit.zone/external/docker:24.0.5
  services:
    - name: registry.vn.eit.zone/external/docker:24.0.5-dind
      alias: docker
  before_script:
    - >
      docker login -u ${REGISTRY_USER} -p ${REGISTRY_PASSWORD} ${REGISTRY};
  script:
    - >
      docker build
      --build-arg BUILD_VERSION=$CI_COMMIT_TAG
      --build-arg http_proxy="${http_proxy}"
      --build-arg https_proxy="${https_proxy}"
      --build-arg no_proxy="${no_proxy}"
      -t ${REGISTRY}/${IMAGE_PATH}:$CI_COMMIT_TAG
      .
    - docker push ${REGISTRY}/${IMAGE_PATH}:$CI_COMMIT_TAG
  after_script:
    - docker logout ${REGISTRY}

# ── Deploy (on git tag, after release) ─────────────────────────────────────────
deploy-app:
  stage: deploy
  only:
    - tags
  tags:
    - vn-small
  image: registry.vn.eit.zone/external/docker:24.0.5
  variables:
    DEPLOY_REPO: "https://gitlab-ci-token:${GITLAB_PF_TOKEN}@git.homecredit.net/country/vn/k8s/deploy/environments/vn/nprod-green/sd-automation-hub.git"
    GIT_STRATEGY: none
  before_script:
    - apk add git
  script:
    - git clone ${DEPLOY_REPO} /tmp/sd-automation-hub
    - cd /tmp/sd-automation-hub
    - git checkout sd-automation-hub-release
    - >
      sed -i
      "s|image: ${REGISTRY}/${IMAGE_PATH}:.*|image: ${REGISTRY}/${IMAGE_PATH}:${CI_COMMIT_TAG}|"
      ./sd-automation-hub/deployment.yml
    - git config user.name "sd-automation-hub-ci"
    - git config user.email "hcvn-sd-automation-hub@homecredit.vn"
    - git add ./sd-automation-hub/deployment.yml
    - git diff --cached --quiet || (git commit -m "Deploy sd-automation-hub:${CI_COMMIT_TAG}" && git push origin sd-automation-hub-release)


