apps-registry:

name: APP_CODE
defaults:
  owner: USER_OR_GROUP@homecredit.vn
  ro_access: SD.NONPROD.RO
  rw_access: SD.NONPROD.RW

spiral-scheme:
name: APP_CODE
defaults:
  vault:
    app_modules:
    - sd
    access_groups_ro:
    - vn.k8s.sd.nonprod.ro
    access_groups_rw:
    - vn.k8s.sd.nonprod.rw
